# === Supabase ===
# https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key
# Só servidor (webhook Stripe) — NUNCA no browser
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key

# === Stripe (conta: acct_1PCKl8PxfxckETDg) ===
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Webhook: https://lucro-mei.vercel.app/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# Crie os produtos/preços no Stripe Dashboard e cole os IDs:
# Plano mensal R$ 39,90 | Plano anual R$ 29,90/mês (R$ 358,80/ano) | Early bird R$ 19,90
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_YEARLY=price_...
STRIPE_PRICE_EARLYBIRD=price_...

# === xAI (categorização de comprovantes com Grok Vision) ===
# https://console.x.ai
XAI_API_KEY=xai-...

# === App ===
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=LucroMEI
# Com Supabase configurado, o login é obrigatório e o trial de 14 dias conta por conta.
# DEMO_MODE já não libera o app sem login quando há URL/ANON do Supabase.
# NEXT_PUBLIC_DEMO_MODE=true
